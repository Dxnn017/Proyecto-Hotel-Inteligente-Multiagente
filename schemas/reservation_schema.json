{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Reservation Payload Schema",
  "description": "Schema para el payload de mensajes de reserva",
  "type": "object",
  "required": ["action"],
  "properties": {
    "action": {
      "type": "string",
      "enum": ["consultar_disponibilidad", "crear_reserva", "cancelar_reserva", "modificar_reserva"]
    },
    "guest_name": {
      "type": "string",
      "minLength": 2
    },
    "guest_email": {
      "type": "string",
      "format": "email"
    },
    "guest_phone": {
      "type": "string"
    },
    "check_in_date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "check_out_date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "room_type": {
      "type": "string",
      "enum": ["simple", "doble", "matrimonial", "suite"]
    },
    "num_guests": {
      "type": "integer",
      "minimum": 1,
      "maximum": 6
    },
    "special_requests": {
      "type": "string"
    },
    "reservation_id": {
      "type": "string"
    },
    "room_assigned": {
      "type": "string"
    },
    "total_nights": {
      "type": "integer",
      "minimum": 1
    },
    "total_cost": {
      "type": "number",
      "minimum": 0
    },
    "available_rooms": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "room_id": { "type": "string" },
          "room_type": { "type": "string" },
          "floor": { "type": "integer" },
          "tarifa_noche": { "type": "number" }
        }
      }
    },
    "response_message": {
      "type": "string"
    }
  }
}
